from collections.abc import Callable
from typing import Any, TypeAlias

RenderFn: TypeAlias = Callable[..., list[str]]

class Renderable:
    render: RenderFn
    flex_basis: int
    grow: int
    width: str | None
    height: str | None
    flat_children: tuple[Any, ...] | None
    flat_spacing: int
    def __init__(
        self,
        render: RenderFn,
        flex_basis: int = 0,
        grow: int = 0,
        width: str | None = None,
        height: str | None = None,
    ) -> None: ...

class Buffer:
    width: int
    height: int
    def __init__(self, width: int, height: int) -> None: ...
    def row_text(self, row: int) -> str: ...

def parse_line(buf: Buffer, row: int, line: str) -> None: ...
def render_full(buf: Buffer) -> str: ...
def render_diff(cur: Buffer, prev: Buffer) -> str: ...
def char_width(ch: str) -> int: ...
def display_width(s: str) -> int: ...
def place_at_offsets(items: list[tuple[int, int, str]]) -> str | None: ...
def pad_columns(cells: list[str], col_widths: list[int], spacing: int) -> str: ...
def flex_distribute(
    bases: list[int], grows: list[int], width: int, spacing: int
) -> list[int]: ...
def make_text_render(
    value: object,
    truncation: str | None,
    pl: int,
    pr: int,
    wrap: bool,
) -> tuple[RenderFn, list[str], int]: ...
def set_text_render_fallback(fn: Callable[..., list[str]]) -> None: ...
def distribute(total: int, weights: list[int]) -> list[int]: ...
def slice_at_width(s: str, max_width: int) -> str: ...
def strip_ansi(s: str) -> str: ...
def truncate(s: str, max_width: int, *, ellipsis: bool = False) -> str: ...
